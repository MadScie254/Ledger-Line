{
  "name": "ledger-line",
  "private": true,
  "version": "0.1.0",
  "description": "Ledgerline enterprise accounting and business operations platform.",
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ledgerline/web",
    "build": "npm run build -w @ledgerline/types && npm run build -w @ledgerline/ui && npm run build -w @ledgerline/ledger-service && npm run build -w @ledgerline/db && npm run build -w @ledgerline/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:ledger": "npm run test -w @ledgerline/ledger-service",
    "db:validate": "prisma validate --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
